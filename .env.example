# Claudio — Personal AI Radio
# Copy this file to .env and fill in your API keys.

# Required: Anthropic API key (Claude AI)
ANTHROPIC_API_KEY=

# Required: MiniMax API key (text-to-speech via WebSocket)
MINIMAX_API_KEY=

# Optional: Fish Audio API key (legacy text-to-speech fallback)
# FISH_AUDIO_API_KEY=

# Optional: OpenWeather API key (weather context)
OPENWEATHER_API_KEY=

# Optional: Feishu app credentials (calendar context)
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Optional: NetEase Cloud Music official API credentials (from https://developer.music.163.com)
# After setting these, run: ncm-cli configure && ncm-cli login
NETEASE_APP_ID=
NETEASE_PRIVATE_KEY=

# Deprecated: NetEase Cookie (fallback only, use AppID + PrivateKey above)
# NETEASE_COOKIE=

# Server port (default: 8080)
PORT=8080

# Optional: Third-party Anthropic-compatible API base URL (e.g. MiniMax, OpenRouter)
# ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic

# Claudio's LLM model (独立于 Claude Code 的模型设置，优先于 CLAUDE_MODEL)
# 支持任何 Anthropic 兼容 API 的模型名，如 deepseek-v4-pro, claude-sonnet-4-6 等
CLAUDIO_MODEL=claude-sonnet-4-6

# ── TTS 语音合成引擎配置 ────────────────────────────────────────────────────────

# TTS 引擎选择（默认 minimax，可选 edge-tts）
# TTS_PROVIDER=minimax

# ── MiniMax TTS（provider=minimax 时生效）──────────────────────────────────────

# MiniMax TTS 音色设置（可选，均有默认值）
# MINIMAX_TTS_VOICE_ID=female-shaonv
# MINIMAX_TTS_SPEED=1.0
# MINIMAX_TTS_VOL=1.0
# MINIMAX_TTS_PITCH=0

# ── Edge-TTS（provider=edge-tts 时生效）────────────────────────────────────────
# 免费使用，无需 API Key。语音名称参考：https://learn.microsoft.com/zh-cn/azure/ai-services/speech-service/language-support
# 常用中文语音：zh-CN-XiaoxiaoNeural（女声）、zh-CN-YunxiNeural（男声）、zh-CN-XiaoyiNeural（女声）
# EDGE_TTS_VOICE=zh-CN-XiaoxiaoNeural
# EDGE_TTS_RATE=+0%
# EDGE_TTS_PITCH=+0Hz

# 播放历史保留天数（默认14天，超过天数的记录自动清理）
PLAY_HISTORY_DAYS=14
